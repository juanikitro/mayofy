{
  "name": "mayofy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "validate:data": "tsx src/validators/validate-dataset.ts --strict-final",
    "validate:intake": "tsx src/validators/validate-dataset.ts --allow-incomplete",
    "validate:mock": "tsx src/validators/validate-dataset.ts data/fixtures/mock-businesses.json --allow-mock",
    "search": "tsx src/research/search-businesses.ts",
    "research:instagram": "tsx src/research/enrich-instagram.ts",
    "shortlist": "tsx src/research/shortlist-businesses.ts",
    "promote": "tsx src/research/promote-shortlist.ts",
    "agent:briefs": "tsx scripts/create-agent-briefs.ts",
    "validate:specs": "tsx src/site-specs/validate-site-specs.ts",
    "compose:local": "tsx src/site-specs/compose-site-specs.ts --provider local",
    "compose:ai": "tsx src/site-specs/compose-site-specs.ts --provider openai",
    "generate": "tsx src/generator/generate-sites.ts --require-real-images --require-agent-frontends",
    "generate:preview": "tsx src/generator/generate-sites.ts",
    "generate:mock": "tsx src/generator/generate-sites.ts data/fixtures/mock-businesses.json --out generated/mock --allow-mock",
    "qa:design": "tsx src/validators/validate-design-gate.ts",
    "qa": "tsx src/validators/validate-generated-sites.ts --require-agent-frontends",
    "qa:client": "tsx src/validators/validate-client-readiness.ts --min-score 85",
    "study:final": "tsx src/delivery/create-final-study.ts",
    "qa:mock": "tsx src/validators/validate-generated-sites.ts generated/mock --allow-mock",
    "import:businesses": "tsx scripts/import-businesses.ts",
    "browse": "node scripts/serve-generated.mjs",
    "catalog:build": "node scripts/build-vercel-catalog.mjs",
    "deploy:prepare": "node scripts/generate-deploy-runs.mjs",
    "typecheck": "tsc --noEmit",
    "qa:impeccable": "node scripts/qa-impeccable.mjs",
    "impeccable:install": "impeccable install --providers=claude,codex --scope=project -y"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "impeccable": "^3.2.1",
    "playwright": "^1.61.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
